<UserControl x:Class="MMONavigator.Controls.EditableMapText"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MMONavigator.Controls"
             FontFamily="Segoe UI"
             FontSize="14"
             Foreground="White"
             FocusManager.IsFocusScope="True"
             Width="180"
             Height="80">

    <UserControl.Resources>

        <!-- ── Resize handle ── -->
        <ControlTemplate x:Key="SquareHandleTemplate" TargetType="Thumb">
            <Border Width="10" Height="10" Background="#FF4FC3F7" BorderBrush="White" BorderThickness="1" CornerRadius="1"/>
        </ControlTemplate>
        <Style x:Key="ResizeHandleStyle" TargetType="Thumb">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Template" Value="{StaticResource SquareHandleTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Toolbar toggle button ── -->
        <Style x:Key="TbToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="21"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="#3A3A3E" BorderBrush="#555" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A6ECC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A9EFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50505A"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2780E0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style x:Key="TbComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="21"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#3A3A3E"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- drop-down popup -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="#2D2D30"
                                        BorderBrush="#555"
                                        BorderThickness="1"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <!-- toggle knob (whole control acts as button) -->
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="14"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,5 L8,0"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Stroke="#888" StrokeThickness="1.2" Fill="Transparent"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#505057"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- selected item display -->
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="5,0,18,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#2D2D30"/>
                        <Setter Property="Foreground" Value="#DDD"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="5,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#1A6ECC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toolbar compact numeric TextBox ── -->
        <Style x:Key="TbNumericStyle" TargetType="TextBox">
            <Setter Property="Height" Value="21"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#3A3A3E"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="CaretBrush" Value="#DDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="True"/>
        </Style>

        <!-- Toolbar label -->
        <Style x:Key="TbLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="4,0,2,0"/>
        </Style>

        <!-- Vertical separator bar -->
        <Style x:Key="TbSepStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Fill" Value="#555"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

    </UserControl.Resources>

    <!--
        Outer Grid: transparent, ClipToBounds=False so handles/toolbar can render outside
        the UserControl's layout bounds. Hosts the Popup alongside the content grid.
    -->
    <Grid ClipToBounds="False" Background="Transparent">

        <!--
            RootGrid: rotates around its center. All visual chrome lives here.
            ClipToBounds=False lets the Handle canvas overflow with handles/toolbar.
        -->
        <Grid x:Name="RootGrid"
              RenderTransformOrigin="0.5,0.5"
              ClipToBounds="False">
            <Grid.RenderTransform>
                <RotateTransform x:Name="MainRotation" Angle="0"/>
            </Grid.RenderTransform>

            <!-- ── Text container ── -->
            <Border x:Name="BackgroundBorder"
                    CornerRadius="{Binding BoxCornerRadius,
                        RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown"
                    MouseLeftButtonUp="Border_MouseLeftButtonUp"
                    MouseMove="Border_MouseMove"
                    Cursor="SizeAll">
                <Grid>
                    <!--
                        EDIT MODE: borderless TextBox.
                        FontWeight/FontStyle propagate from the UserControl via property inheritance.
                        Padding is set from code-behind (ApplyFontProperties).
                        Escape → Display mode.
                    -->
                    <TextBox x:Name="EditBox"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="Transparent"
                             CaretBrush="White"
                             SelectionBrush="#804FC3F7"
                             VerticalScrollBarVisibility="Hidden"
                             FontFamily="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                             FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                             Opacity="{Binding TextOpacity, RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                             TextAlignment="{Binding TextAlign, RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                             KeyDown="EditBox_KeyDown"
                             Visibility="Visible"
                             Focusable="True"
                             IsTabStop="True">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                              Focusable="True" 
                                                              Background="Transparent"
                                                              Margin="{TemplateBinding Padding}"
                                                              HorizontalScrollBarVisibility="Hidden"
                                                              VerticalScrollBarVisibility="Hidden"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!--
                        DISPLAY MODE: styled TextBlock.
                        Double-click → Edit mode.
                    -->
                    <TextBlock x:Name="DisplayBlock"
                               TextWrapping="Wrap"
                               FontFamily="{Binding FontFamily,
                                   RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                               FontSize="{Binding FontSize,
                                   RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                               Foreground="{Binding Foreground,
                                   RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                               Background="Transparent"
                               Opacity="{Binding TextOpacity,
                                   RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                               TextAlignment="{Binding TextAlign,
                                   RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                               MouseLeftButtonDown="DisplayBlock_MouseLeftButtonDown"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- ── Dashed selection frame ── -->
            <Rectangle x:Name="SelectionFrame"
                       Stroke="#FF4FC3F7"
                       StrokeThickness="1.5"
                       StrokeDashArray="4,3"
                       RadiusX="{Binding BoxCornerRadius.TopLeft,
                           RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                       RadiusY="{Binding BoxCornerRadius.TopLeft,
                           RelativeSource={RelativeSource AncestorType=local:EditableMapText}}"
                       Fill="Transparent"
                       IsHitTestVisible="False"
                       SnapsToDevicePixels="True"/>

            <!--
                ── Handle canvas ──
                ClipToBounds=False is essential: resize handles, rotation thumb, toolbar, and
                stamp button all render outside the control's layout bounds and remain
                hit-testable because WPF's visual-tree hit-test is not clipped here.
            -->
            <Canvas x:Name="HandleCanvas" ClipToBounds="False" IsHitTestVisible="True">

                <!-- Rotation connector: dashed line rising from top-center -->
                <Line x:Name="RotationConnectorLine"
                      Stroke="#FF4FC3F7"
                      StrokeThickness="1.5"
                      StrokeDashArray="3,3"
                      IsHitTestVisible="False"/>

                <!-- Rotation thumb (circle) -->
                <Thumb x:Name="RotationHandle"
                       Width="14" Height="14"
                       Cursor="Hand"
                       ToolTip="Drag to rotate"
                       DragStarted="RotationHandle_DragStarted"
                       DragDelta="RotationHandle_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Grid>
                                <Ellipse Fill="#FF2D7D9A" Stroke="White" StrokeThickness="1.5"/>
                                <Path Data="M7,2.5 A4.5,4.5 0 0 1 11,7 L12.5,5.5 M7,11.5 A4.5,4.5 0 0 1 3,7 L1.5,8.5"
                                      Stroke="White" StrokeThickness="1.2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Fill="Transparent" IsHitTestVisible="False"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- ── 8 resize handles ── -->
                <Thumb x:Name="NwHandle" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE" DragDelta="NwHandle_DragDelta"/>
                <Thumb x:Name="NHandle"  Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNS"   DragDelta="NHandle_DragDelta"/>
                <Thumb x:Name="NeHandle" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW" DragDelta="NeHandle_DragDelta"/>
                <Thumb x:Name="EHandle"  Style="{StaticResource ResizeHandleStyle}" Cursor="SizeWE"   DragDelta="EHandle_DragDelta"/>
                <Thumb x:Name="SeHandle" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNWSE" DragDelta="SeHandle_DragDelta"/>
                <Thumb x:Name="SHandle"  Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNS"   DragDelta="SHandle_DragDelta"/>
                <Thumb x:Name="SwHandle" Style="{StaticResource ResizeHandleStyle}" Cursor="SizeNESW" DragDelta="SwHandle_DragDelta"/>
                <Thumb x:Name="WHandle"  Style="{StaticResource ResizeHandleStyle}" Cursor="SizeWE"   DragDelta="WHandle_DragDelta"/>

                <!-- ── Stamp button ── floats to the right, vertically centered -->
                <Button x:Name="StampButton"
                        Width="24" Height="24"
                        Cursor="Hand"
                        ToolTip="Stamp text onto map"
                        Click="StampButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="Bg" Fill="#FF2D7D9A" Stroke="White" StrokeThickness="1.5"/>
                                <Path Data="M6,12 L10,16 L18,7"
                                      Stroke="White" StrokeThickness="2.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent" IsHitTestVisible="False"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Fill" Value="#FF3A9DBF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Fill" Value="#FF1A5C74"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!--
                    ── Contextual formatting toolbar ──
                    Visible only when State == Edit.
                    Positioned below the content box in UpdateHandlePositions().

                    RenderTransformOrigin="0,0" + ScaleTransform(1/ZoomLevel) keeps the
                    toolbar at constant screen-pixel size regardless of map zoom level.
                    Because the map Canvas applies a LayoutTransform (ZoomLevel scale),
                    everything inside is visually scaled by ZoomLevel. The counter-scale
                    here undoes that zoom:  ZoomLevel × (1/ZoomLevel) = 1× screen size.
                -->
                <Border x:Name="ToolbarContainer"
                        RenderTransformOrigin="0,0"
                        Background="#F0202426"
                        BorderBrush="#3A4450"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,4">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ToolbarInverseScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>

                    <StackPanel>

                        <!-- ══ Row 1: Text formatting ══ -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">

                            <!-- Font family -->
                            <ComboBox x:Name="FontFamilyCombo"
                                      Style="{StaticResource TbComboStyle}"
                                      Width="108"
                                      ToolTip="Font family"
                                      SelectionChanged="FontFamilyCombo_SelectionChanged"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Font size -->
                            <TextBox x:Name="FontSizeBox"
                                     Style="{StaticResource TbNumericStyle}"
                                     Width="36"
                                     ToolTip="Font size (pt)"
                                     Focusable="True" IsTabStop="True"
                                     PreviewTextInput="FontSizeBox_PreviewTextInput"
                                     KeyDown="FontSizeBox_KeyDown"
                                     LostFocus="FontSizeBox_LostFocus"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Bold -->
                            <ToggleButton x:Name="BoldBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          ToolTip="Bold (Ctrl+B)"
                                          IsChecked="{Binding IsBold,
                                              RelativeSource={RelativeSource AncestorType=local:EditableMapText}}">
                                <TextBlock Text="B" FontWeight="Bold" Foreground="#DDD" FontSize="12" FontFamily="Georgia"/>
                            </ToggleButton>

                            <!-- Italic -->
                            <ToggleButton x:Name="ItalicBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          Margin="2,0,0,0"
                                          ToolTip="Italic (Ctrl+I)"
                                          IsChecked="{Binding IsItalic,
                                              RelativeSource={RelativeSource AncestorType=local:EditableMapText}}">
                                <TextBlock Text="I" FontStyle="Italic" Foreground="#DDD" FontSize="12" FontFamily="Georgia"/>
                            </ToggleButton>

                            <!-- Underline -->
                            <ToggleButton x:Name="UnderlineBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          Margin="2,0,0,0"
                                          ToolTip="Underline (Ctrl+U)"
                                          IsChecked="{Binding IsUnderline,
                                              RelativeSource={RelativeSource AncestorType=local:EditableMapText}}">
                                <TextBlock Text="U" TextDecorations="Underline" Foreground="#DDD" FontSize="12" FontFamily="Georgia"/>
                            </ToggleButton>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Text color swatch -->
                            <Border x:Name="TextColorSwatch"
                                    Width="22" Height="21"
                                    BorderBrush="#777" BorderThickness="1" CornerRadius="2"
                                    Cursor="Hand"
                                    ToolTip="Text color"
                                    MouseLeftButtonDown="TextColorSwatch_Click"/>

                            <!-- Text opacity -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="A" ToolTip="Text opacity"/>
                            <Slider x:Name="TextOpacitySlider"
                                    Width="55"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Minimum="0" Maximum="1"
                                    TickFrequency="0.05" IsSnapToTickEnabled="False"
                                    ToolTip="Text opacity"
                                    Value="{Binding TextOpacity,
                                        RelativeSource={RelativeSource AncestorType=local:EditableMapText},
                                        Mode=TwoWay}"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Alignment buttons: Left / Center / Right / Justify -->
                            <ToggleButton x:Name="AlignLeftBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          ToolTip="Align left"
                                          Tag="Left"
                                          Click="AlignBtn_Click">
                                <Path Width="11" Height="10" Stretch="Uniform" Fill="Transparent"
                                      Stroke="#CCC" StrokeThickness="1.3"
                                      Data="M0,0.5 L8,0.5 M0,3.5 L5,3.5 M0,6.5 L8,6.5 M0,9.5 L6,9.5"/>
                            </ToggleButton>

                            <ToggleButton x:Name="AlignCenterBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          Margin="2,0,0,0"
                                          ToolTip="Align center"
                                          Tag="Center"
                                          Click="AlignBtn_Click">
                                <Path Width="11" Height="10" Stretch="Uniform" Fill="Transparent"
                                      Stroke="#CCC" StrokeThickness="1.3"
                                      Data="M0,0.5 L8,0.5 M1.5,3.5 L6.5,3.5 M0,6.5 L8,6.5 M2,9.5 L6,9.5"/>
                            </ToggleButton>

                            <ToggleButton x:Name="AlignRightBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          Margin="2,0,0,0"
                                          ToolTip="Align right"
                                          Tag="Right"
                                          Click="AlignBtn_Click">
                                <Path Width="11" Height="10" Stretch="Uniform" Fill="Transparent"
                                      Stroke="#CCC" StrokeThickness="1.3"
                                      Data="M0,0.5 L8,0.5 M3,3.5 L8,3.5 M0,6.5 L8,6.5 M2,9.5 L8,9.5"/>
                            </ToggleButton>

                            <ToggleButton x:Name="AlignJustifyBtn"
                                          Style="{StaticResource TbToggleStyle}"
                                          Margin="2,0,0,0"
                                          ToolTip="Justify"
                                          Tag="Justify"
                                          Click="AlignBtn_Click">
                                <Path Width="11" Height="10" Stretch="Uniform" Fill="Transparent"
                                      Stroke="#CCC" StrokeThickness="1.3"
                                      Data="M0,0.5 L8,0.5 M0,3.5 L8,3.5 M0,6.5 L8,6.5 M0,9.5 L8,9.5"/>
                            </ToggleButton>

                        </StackPanel>

                        <!-- ══ Row 2: Box / container styling ══ -->
                        <StackPanel Orientation="Horizontal">

                            <!-- Box background color -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="Fill" Margin="0,0,2,0" ToolTip="Box fill color"/>
                            <Border x:Name="BoxBgColorSwatch"
                                    Width="22" Height="21"
                                    BorderBrush="#777" BorderThickness="1" CornerRadius="2"
                                    Cursor="Hand"
                                    ToolTip="Background color"
                                    MouseLeftButtonDown="BoxBgColorSwatch_Click"/>

                            <!-- Background opacity -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="α" ToolTip="Background opacity"/>
                            <Slider x:Name="BoxOpacitySlider"
                                    Width="55"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Minimum="0" Maximum="1"
                                    ToolTip="Background opacity"
                                    Value="{Binding BoxBackgroundOpacity,
                                        RelativeSource={RelativeSource AncestorType=local:EditableMapText},
                                        Mode=TwoWay}"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Border color -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="Border" ToolTip="Box border color"/>
                            <Border x:Name="BorderColorSwatch"
                                    Width="22" Height="21"
                                    BorderBrush="#777" BorderThickness="1" CornerRadius="2"
                                    Cursor="Hand"
                                    ToolTip="Border color"
                                    MouseLeftButtonDown="BorderColorSwatch_Click"/>

                            <!-- Border thickness -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="px" ToolTip="Border thickness"/>
                            <Slider x:Name="BorderThicknessSlider"
                                    Width="50"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Minimum="0" Maximum="8"
                                    TickFrequency="0.5"
                                    ToolTip="Border thickness (px)"
                                    ValueChanged="BorderThicknessSlider_ValueChanged"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Corner radius -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="Radius" ToolTip="Corner radius"/>
                            <Slider x:Name="CornerRadiusSlider"
                                    Width="50"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Minimum="0" Maximum="30"
                                    ToolTip="Corner radius"
                                    ValueChanged="CornerRadiusSlider_ValueChanged"/>

                            <Rectangle Style="{StaticResource TbSepStyle}"/>

                            <!-- Text padding -->
                            <TextBlock Style="{StaticResource TbLabelStyle}" Text="Pad" ToolTip="Text padding (px)"/>
                            <Slider x:Name="TextPaddingSlider"
                                    Width="50"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Minimum="0" Maximum="24"
                                    ToolTip="Text padding (px)"
                                    ValueChanged="TextPaddingSlider_ValueChanged"/>

                        </StackPanel>

                    </StackPanel>
                </Border>

            </Canvas>
        </Grid>

        <!--
            ── Shared color-picker popup ──
            Lives in the outer Grid (alongside RootGrid) so it renders in a separate
            WPF HwndSource and is not affected by the RootGrid's RotateTransform.
            Placement=Mouse positions it at the cursor when opened from code.
            Swatches are generated in code-behind (PopulateColorPicker).
        -->
        <Popup x:Name="ColorPickerPopup"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Placement="Mouse">
            <Border Background="#F0202426"
                    BorderBrush="#3A4450"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="5">
                <WrapPanel x:Name="ColorSwatchPanel"
                           Width="168"
                           ItemWidth="24"
                           ItemHeight="24"/>
            </Border>
        </Popup>

    </Grid>
</UserControl>
