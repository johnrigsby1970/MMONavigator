<Window x:Class="MMONavigator.Views.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MMONavigator.Views"
        mc:Ignorable="d"
        Title="Map" Height="600" Width="800"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Opacity="{Binding EffectiveOpacity}"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Rectangle Grid.Row="0" Fill="#3E3E42" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Visibility="{Binding UIVisibility}"/>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,0,0,0" Visibility="{Binding UIVisibility}">
            <TextBlock Text="Map Overlay" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding UIVisibility}">
            <Button Content="0" FontFamily="Marlett" Width="30" Click="MinimizeButton_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
            <Button Content="r" FontFamily="Marlett" Width="30" Click="CloseButton_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <Grid Grid.Row="1" Background="#333333" Visibility="{Binding UIVisibility}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" >
                <Button Content="Pick Image" Click="PickImage_Click" Margin="5,2,5,2" Padding="5,2"/>
                <Button Content="Calibrate" Click="Calibrate_Click" Margin="0,2,5,2" Padding="5,2"/>
                <Button Content="Save Map" Click="SaveMap_Click" Margin="0,2,5,2" Padding="5,2" IsEnabled="{Binding Settings.IsCalibrated}"/>
                <Button Content="Load Map" Click="LoadMap_Click" Margin="0,2,5,2" Padding="5,2"/>
                <TextBlock x:Name="StatusTextBlock" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Text="Status: Ready"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                <TextBlock Text="{Binding HoverCoordinatesLabel}" Foreground="#AAAAAA" VerticalAlignment="Center" FontSize="11" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding CurrentCoordinatesLabel}" Foreground="#AAAAAA" VerticalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </Grid>

        <!-- Map Area -->
        <ScrollViewer x:Name="MapScrollViewer" Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="-1" Background="#2D2D2D" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel">
            <Canvas x:Name="MapCanvas" Width="{Binding MapImage.PixelWidth}" Height="{Binding MapImage.PixelHeight}" 
                    MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown" MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp" MouseMove="MapCanvas_MouseMove" Background="Black">
                <Canvas.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="SetDestinationMenuItem" Header="Set Destination" IsCheckable="True" Click="SetDestination_Click" IsEnabled="{Binding Settings.IsCalibrated}" />
                        <MenuItem x:Name="AddPinMenuItem" Header="Add Pin" IsCheckable="True" Click="AddPin_Click" IsEnabled="{Binding Settings.IsCalibrated}" />
                        <Separator />
                        <MenuItem Header="Show Locations" IsCheckable="True" IsChecked="{Binding ShowLocations}" IsEnabled="{Binding Settings.IsCalibrated}" />
                    </ContextMenu>
                </Canvas.ContextMenu>
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="MapScaleTransform" ScaleX="{Binding Settings.ZoomLevel}" ScaleY="{Binding Settings.ZoomLevel}" />
                </Canvas.LayoutTransform>
                <Image Source="{Binding MapImage}" Stretch="None"/>
                
                <!-- Position Marker -->
                <Ellipse x:Name="PulseCircle" Width="10" Height="10" Stroke="Yellow" StrokeThickness="2"
                         Visibility="{Binding MarkerVisibility}"
                         Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}"
                         Margin="-5,-5" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Name="PulseStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.2" Duration="0:0:1.5" AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Ellipse x:Name="PositionMarker" Width="10" Height="10" Fill="Red" Stroke="White" StrokeThickness="1"
                         Visibility="{Binding MarkerVisibility}"
                         Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}"
                         Margin="-5,-5">
                    <Ellipse.RenderTransform>
                         <TranslateTransform X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
                
                <!-- Heading Arrow -->
                <Path Data="M 0,-8 L 4,2 L 0,0 L -4,2 Z" Fill="Red" Stroke="White" StrokeThickness="1"
                      Visibility="{Binding HeadingVisibility}"
                      Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}">
                    <Path.RenderTransform>
                        <RotateTransform Angle="{Binding MarkerHeading}" />
                    </Path.RenderTransform>
                </Path>

                <!-- Destination Marker -->
                <Ellipse x:Name="DestinationPulseCircle" Width="10" Height="10" Stroke="Purple" StrokeThickness="2"
                         Visibility="{Binding TargetMarkerVisibility}"
                         Canvas.Left="{Binding TargetMarkerX}" Canvas.Top="{Binding TargetMarkerY}"
                         Margin="-5,-5" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <Trigger Property="Visibility" Value="Visible">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard Name="DestinationPulseStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.2" Duration="0:0:1.5" AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="DestinationPulseStoryboard" />
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <Ellipse x:Name="DestinationMarker" Width="10" Height="10" Fill="Yellow" Stroke="Black" StrokeThickness="1"
                         Visibility="{Binding TargetMarkerVisibility}"
                         Canvas.Left="{Binding TargetMarkerX}" Canvas.Top="{Binding TargetMarkerY}"
                         Margin="-5,-5">
                    <Ellipse.RenderTransform>
                         <TranslateTransform X="0" Y="0"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Calibration Markers -->
                <Ellipse x:Name="CalibMarker1" Width="8" Height="8" Fill="Blue" Stroke="White" StrokeThickness="1" Visibility="Collapsed" Margin="-4,-4"/>
                <Ellipse x:Name="CalibMarker2" Width="8" Height="8" Fill="Green" Stroke="White" StrokeThickness="1" Visibility="Collapsed" Margin="-4,-4"/>

                <!-- Location Indicators -->
                <ItemsControl ItemsSource="{Binding Locations}" Visibility="{Binding ShowLocations, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding PixelX}" />
                            <Setter Property="Canvas.Top" Value="{Binding PixelY}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="8" Height="8" Fill="DeepSkyBlue" Stroke="White" StrokeThickness="1" Margin="-4,-4" Visibility="{Binding Visibility}">
                                <Ellipse.ToolTip>
                                    <ToolTip Content="{Binding Tooltip}" />
                                </Ellipse.ToolTip>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </ScrollViewer>

        <!-- Opacity Slider -->
        <Border Grid.Row="3" Background="#333333" Padding="10,5,10,5" Visibility="{Binding UIVisibility}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Opacity" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"/>
                <Slider Width="100" Minimum="0.1" Maximum="1.0" Value="{Binding Opacity}" VerticalAlignment="Center" 
                        TickFrequency="0.05" IsSnapToTickEnabled="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
