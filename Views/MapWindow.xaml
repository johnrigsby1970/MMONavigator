<controls:ChildWindow x:Class="MMONavigator.Views.MapWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:MMONavigator.Views"
                      xmlns:controls="clr-namespace:MMONavigator.Controls"
                      xmlns:helpers="clr-namespace:MMONavigator.Helpers"
                      mc:Ignorable="d"
                      Title="Map"
                      WindowStyle="None"
                      AllowsTransparency="True"
                      ResizeMode="CanResizeWithGrip"
                      Topmost="True"
                      Focusable="False"
                      Opacity="1"
                      IsHitTestVisible="True"
                      Top="{Binding AppSettings.MapWindowPlacement.Top, Mode=TwoWay}"
                      Left="{Binding AppSettings.MapWindowPlacement.Left, Mode=TwoWay}"
                      Width="{Binding AppSettings.MapWindowPlacement.Width, Mode=TwoWay}"
                      Height="{Binding AppSettings.MapWindowPlacement.Height, Mode=TwoWay}"
                      WindowState="{Binding AppSettings.MapWindowPlacement.State, Mode=TwoWay}"
                      Background="Transparent">
    <!--to allow click through I changed this -->
    <!--Background="#01000000"-->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:HalfValueConverter x:Key="HalfValueConverter" />
        <helpers:ComparisonConverter x:Key="ComparisonConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:CenterConverter x:Key="CenterConverter" />

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Background" Value="#3E3E42" />

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UIVisibility}" Value="Collapsed">
                                            <Setter Property="Background" Value="{x:Null}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1" Grid.Row="0"
                                       AutomationProperties.AutomationId="VerticalScrollBar"
                                       Cursor="Arrow"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       Minimum="0"
                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       ViewportSize="{TemplateBinding ViewportHeight}" />

                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0" Grid.Row="1"
                                       AutomationProperties.AutomationId="HorizontalScrollBar"
                                       Cursor="Arrow"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Minimum="0"
                                       Orientation="Horizontal"
                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                       ViewportSize="{TemplateBinding ViewportWidth}" />

                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="Transparent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ResizeGrip}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ResizeGrip}">
                        <Grid Background="{Binding EffectiveBackgroundBrush}"
                              Visibility="{Binding UIVisibility}"
                              SnapsToDevicePixels="True">
                            <Border x:Name="GripVisual" Opacity="0">
                                <Path Data="M1,10 L3,10 M5,10 L7,10 M9,10 L11,10 M5,6 L7,6 M9,6 L11,6 M9,2 L11,2"
                                      Stroke="#FFB0B0B0"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,2,2" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger
                                Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="True">
                                <Setter TargetName="GripVisual" Property="Opacity" Value="1" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Name="myMapGrid" Background="Transparent" IsHitTestVisible="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0"
                Style="{StaticResource MainBorderStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                Visibility="{Binding UIVisibility}"
                IsHitTestVisible="True"
                Background="{Binding EffectiveBackgroundBrush}"
                Focusable="False" />
        <StackPanel Background="{Binding EffectiveBackgroundBrush}" Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Left" Margin="5,0,0,0" Visibility="{Binding UIVisibility}" Focusable="False">

            <TextBlock Text="{Binding AppTitle}" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"
                       Focusable="False" />
        </StackPanel>
        <StackPanel Background="{Binding EffectiveBackgroundBrush}" Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" Visibility="{Binding UIVisibility}" Focusable="False">
            <Button Content="0" FontFamily="Marlett" Width="30" Click="MinimizeButton_Click" Background="Transparent"
                    Foreground="White" BorderThickness="0" Focusable="False" />
            <Button Content="2" FontFamily="Marlett" Width="30" Click="NormalButton_Click" Background="Transparent"
                    Foreground="White" BorderThickness="0" Focusable="False" />
            <Button Content="1" FontFamily="Marlett" Width="30" Click="MaximizeButton_Click" Background="Transparent"
                    Foreground="White" BorderThickness="0" Focusable="False" />
            <Button Content="r" FontFamily="Marlett" Width="30" Click="CloseButton_Click" Background="Transparent"
                    Foreground="White" BorderThickness="0" Focusable="False" />
        </StackPanel>

        <Grid Grid.Row="1"
              Style="{StaticResource MainGridStyle}"
              Visibility="{Binding UIVisibility}"
              Focusable="False">

            <Menu Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <MenuItem Header="_File" Foreground="White">
                    <MenuItem Header="_Pick Image" Click="PickImage_Click" Foreground="Black" />
                    <MenuItem Header="_Load Map" Click="LoadMap_Click" Foreground="Black" />
                    <Separator />
                    <MenuItem Header="_Save Map" Click="SaveMap_Click"
                              IsEnabled="{Binding Settings.IsCalibrated}" Foreground="Black" />
                </MenuItem>
            </Menu>

            <Button Style="{StaticResource CalibrationButtonStyle}"
                    Content="Calibrate" Click="Calibrate_Click"
                    Margin="0,2,5,2"
                    Padding="5,2"
                    HorizontalAlignment="Right"
                    Width="70"
                    Focusable="False"
                    ToolTip="Map two positions on the image to locations in the game by their X/Y coordinates." />

            <!-- <Button Style="{StaticResource PrimaryButtonStyle}" Content="Pick Image" Click="PickImage_Click" -->
            <!--         Margin="5,2,5,2" Padding="5,2" Focusable="False" -->
            <!--         ToolTip="Select a new map image to use in the game." /> -->

            <!-- <Button Style="{StaticResource MainButtonStyle}" Content="Save Map" Click="SaveMap_Click" -->
            <!--         Margin="0,2,5,2" Padding="5,2" -->
            <!--         ToolTip="Save a calibrated map so that you can select it again in the future." -->
            <!--         IsEnabled="{Binding Settings.IsCalibrated}" Focusable="False" /> -->
            <!-- <Button Style="{StaticResource MainButtonStyle}" Content="Load Map" Click="LoadMap_Click" -->
            <!--         Margin="0,2,5,2" Padding="5,2" Focusable="False" -->
            <!--         ToolTip="Load a saved calibrated map. To create a new map, use the 'Pick Image' button." /> -->
            <!-- <TextBlock x:Name="StatusTextBlock" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" -->
            <!--            Text="Status: Ready" Focusable="False" /> -->

            <!-- <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" Focusable="False"> -->
            <!--     <TextBlock Text="{Binding HoverCoordinatesLabel}" Foreground="#AAAAAA" VerticalAlignment="Center" -->
            <!--                FontSize="11" Margin="0,0,15,0" Focusable="False" /> -->
            <!--     <TextBlock Text="{Binding CurrentCoordinatesLabel}" Foreground="#AAAAAA" VerticalAlignment="Center" -->
            <!--                FontSize="11" Focusable="False" /> -->
            <!-- </StackPanel> -->
        </Grid>
        <Grid Grid.Row="2">
            <!-- Map Area -->
            <ScrollViewer x:Name="MapScrollViewer"
                          Panel.ZIndex="-1"
                          ScrollChanged="MapScroll_ScrollChanged"
                          Background="{Binding EffectiveTransparentBrush}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MapScrollViewer_PreviewMouseWheel"
                          Focusable="False">

                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type RepeatButton}" x:Key="ScrollBarButton">
                        <Setter Property="Opacity" Value="{Binding EffectiveOpacity}" />
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Opacity" Value="{Binding EffectiveOpacity}" />
                        <Setter Property="Background" Value="{Binding EffectiveTransparentBrush}" />
                        <Setter Property="Width" Value="12" />
                        <Setter Property="Visibility" Value="Collapsed" />

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">

                                    <Grid x:Name="Bg" Background="{TemplateBinding Background}"
                                          SnapsToDevicePixels="true">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true"
                                               IsEnabled="{TemplateBinding IsEnabled}">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Grid>
                                                                <Border Background="Black" CornerRadius="2"
                                                                        BorderBrush="White" BorderThickness="0.75" />
                                                                <Border Margin="2">
                                                                    <Border.Background>
                                                                        <DrawingBrush TileMode="Tile"
                                                                                Viewport="0,0,4,4"
                                                                                ViewportUnits="Absolute">
                                                                            <DrawingBrush.Drawing>
                                                                                <GeometryDrawing Brush="#AA444444">
                                                                                    <GeometryDrawing.Geometry>
                                                                                        <EllipseGeometry Center="2,2"
                                                                                            RadiusX="2"
                                                                                            RadiusY="2" />
                                                                                    </GeometryDrawing.Geometry>
                                                                                </GeometryDrawing>
                                                                            </DrawingBrush.Drawing>
                                                                        </DrawingBrush>
                                                                    </Border.Background>
                                                                </Border>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition
                                        Binding="{Binding DataContext.UIVisibility, RelativeSource={RelativeSource TemplatedParent}}"
                                        Value="Visible" />
                                    <Condition
                                        Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}"
                                        Value="Visible" />
                                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}"
                                               Value="Vertical" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition
                                        Binding="{Binding DataContext.UIVisibility, RelativeSource={RelativeSource TemplatedParent}}"
                                        Value="Visible" />
                                    <Condition
                                        Binding="{Binding ComputedHorizontalScrollBarVisibility, RelativeSource={RelativeSource TemplatedParent}}"
                                        Value="Visible" />
                                    <Condition Binding="{Binding Orientation, RelativeSource={RelativeSource Self}}"
                                               Value="Horizontal" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="Height" Value="12" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Resources>
                <Canvas x:Name="MapCanvas"
                        Width="{Binding MapImage.Width}"
                        Height="{Binding MapImage.Height}"
                        MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                        MouseMove="MapCanvas_MouseMove"
                        Focusable="False">
                    <Canvas.ContextMenu>
                        <ContextMenu Focusable="False">
                            <MenuItem x:Name="SetDestinationMenuItem" Header="Set Destination" IsCheckable="True"
                                      Click="SetDestination_Click" IsEnabled="{Binding Settings.IsCalibrated}"
                                      Focusable="True" />
                            <MenuItem x:Name="AddPinMenuItem" Header="Add Pin" IsCheckable="True" Click="AddPin_Click"
                                      IsEnabled="{Binding Settings.IsCalibrated}" Focusable="True" />
                            <Separator Focusable="False" />
                            <MenuItem Header="Show Locations" IsCheckable="True" IsChecked="{Binding ShowLocations}"
                                      IsEnabled="{Binding Settings.IsCalibrated}" Focusable="False" />
                            <MenuItem Header="Show Calibration Markers" IsCheckable="True"
                                      IsChecked="{Binding ShowCalibrationMarkers}"
                                      IsEnabled="{Binding Settings.IsCalibrated}" Focusable="False" />
                            <MenuItem Header="Show Breadcrumbs" IsCheckable="True" IsChecked="{Binding ShowBreadcrumb}"
                                      IsEnabled="{Binding Settings.IsCalibrated}" Focusable="False" />
                            <MenuItem Header="Show Fog of War" IsCheckable="True" IsChecked="{Binding ShowFogOfWar}"
                                      IsEnabled="{Binding Settings.IsCalibrated}" Focusable="False" />
                            <MenuItem Header="Center Current Position"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsFollowModeActive}"
                                      Focusable="False" />
                            <!-- <Separator Focusable="False" /> -->
                            <!-- <MenuItem Header="Create Challenge" IsCheckable="False" IsEnabled="{Binding Settings.IsCalibrated}" -->
                            <!--           Click="CreateChallenge_Click"></MenuItem> -->

                            <Separator Focusable="False">
                                <Separator.Style>
                                    <Style TargetType="Separator">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UIVisibility}" Value="Collapsed">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Separator.Style>
                            </Separator>
                            <MenuItem Header="Show Controls"
                                      IsCheckable="False"
                                      Click="ShowControls_Click">
                                <MenuItem.Style>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UIVisibility}" Value="Collapsed">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MenuItem.Style>
                            </MenuItem>
                            <MenuItem Header="Hide Window"
                                      IsCheckable="True"
                                      Click="MinimizeButton_Click">
                                <MenuItem.Style>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UIVisibility}" Value="Collapsed">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MenuItem.Style>
                            </MenuItem>


                        </ContextMenu>
                    </Canvas.ContextMenu>
                    <Canvas.LayoutTransform>
                        <ScaleTransform x:Name="MapScaleTransform" ScaleX="{Binding Settings.ZoomLevel}"
                                        ScaleY="{Binding Settings.ZoomLevel}" />
                    </Canvas.LayoutTransform>
                    <Grid Opacity="{Binding EffectiveOpacity}">

                        <!-- <Grid Width="800" Height="600"> -->
                        <!--     <Image Canvas.ZIndex="0" x:Name="MapImageElement" -->
                        <!--     PreviewMouseLeftButtonDown="MapImageElement_PreviewMouseLeftButtonDown" -->
                        <!--     Source="{Binding MapImage}" Stretch="None" Focusable="False" /> -->
                        <!--     <Border Background="#3E3E42"  -->
                        <!--             HorizontalAlignment="Center"  -->
                        <!--             VerticalAlignment="Center" -->
                        <!--             x:Name="PlaceholderBorder" -->
                        <!--             Visibility="{Binding MapImage, Converter={StaticResource NullToVisibilityConverter}}"> -->
                        <!--         <TextBlock Text="Load Map or Pick Image"  -->
                        <!--                    Foreground="White"  -->
                        <!--                    FontSize="24" -->
                        <!--                    HorizontalAlignment="Center"  -->
                        <!--                    VerticalAlignment="Center"  -->
                        <!--                    FontWeight="Bold"/> -->
                        <!--     </Border> -->
                        <!-- </Grid> -->

                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Canvas.ZIndex="0" x:Name="MapImageElement"
                                   PreviewMouseLeftButtonDown="MapImageElement_PreviewMouseLeftButtonDown"
                                   Source="{Binding MapImage}" Stretch="None" Focusable="False" />
                        </Grid>

                        <Image Canvas.ZIndex="10"
                               Source="{Binding FogImage}" Stretch="None" Focusable="False"
                               IsHitTestVisible="False">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Settings.IsCalibrated}" Value="True" />
                                                <Condition Binding="{Binding Settings.ShowFogOfWar}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                        <Image Canvas.ZIndex="10"
                               Source="{Binding BreadcrumbImage}" Stretch="None" Focusable="False"
                               IsHitTestVisible="False"
                               Visibility="{Binding ShowBreadcrumb, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                    <!-- Position Marker -->
                    <Ellipse x:Name="PulseCircle" Width="12.5" Height="12.5" Stroke="Yellow" StrokeThickness="2"
                             Visibility="{Binding CurrentPositionMarkerVisibility}"
                             Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}"
                             Margin="-6.25,-6.25" RenderTransformOrigin="0.5,0.5" Focusable="False"
                             Canvas.ZIndex="40">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <Trigger Property="Visibility" Value="Visible">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard Name="PulseStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.2" Duration="0:0:1.5"
                                                                     AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseStoryboard" />
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse x:Name="PositionMarker" Width="12.5" Height="12.5" Fill="Red" Stroke="White"
                             StrokeThickness="1"
                             Visibility="{Binding CurrentPositionMarkerVisibility}"
                             Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}"
                             Margin="-6.25,-6.25" Focusable="False" Canvas.ZIndex="40">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Heading Arrow -->
                    <Path Data="M 0,-8 L 4,2 L 0,0 L -4,2 Z" Fill="Red" Stroke="White" StrokeThickness="1"
                          Visibility="{Binding HeadingVisibility}"
                          Canvas.Left="{Binding MarkerX}" Canvas.Top="{Binding MarkerY}" Focusable="False"
                          Canvas.ZIndex="40">
                        <Path.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1.25" ScaleY="1.25" />
                                <RotateTransform Angle="{Binding MarkerHeading}" />
                            </TransformGroup>
                        </Path.RenderTransform>
                    </Path>

                    <!-- Destination Marker -->
                    <Ellipse x:Name="DestinationPulseCircle" Width="12.5" Height="12.5" Stroke="Purple"
                             StrokeThickness="2"
                             Visibility="{Binding TargetMarkerVisibility}"
                             Canvas.Left="{Binding TargetMarkerX}" Canvas.Top="{Binding TargetMarkerY}"
                             Margin="-6.25,-6.25" RenderTransformOrigin="0.5,0.5" Focusable="False"
                             Canvas.ZIndex="40">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <Trigger Property="Visibility" Value="Visible">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard Name="DestinationPulseStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                        From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                        From="1.0" To="3.0" Duration="0:0:1.5" AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <QuadraticEase EasingMode="EaseInOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.2" Duration="0:0:1.5"
                                                                     AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="DestinationPulseStoryboard" />
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse x:Name="DestinationMarker" Width="12.5" Height="12.5" Fill="Yellow" Stroke="Black"
                             StrokeThickness="1"
                             Visibility="{Binding TargetMarkerVisibility}"
                             Canvas.Left="{Binding TargetMarkerX}" Canvas.Top="{Binding TargetMarkerY}"
                             Margin="-6.25,-6.25" Focusable="False" Canvas.ZIndex="40">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Calibration Markers -->
                    <Grid Opacity="{Binding EffectiveOpacity}" x:Name="CalibMarker1" Background="Transparent"
                          Width="30"
                          Height="30" Margin="-15,-15" Focusable="False">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Settings.IsCalibrated}" Value="True" />
                                            <Condition Binding="{Binding Settings.ShowCalibrationMarkers}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Ellipse Width="10" Height="10" Fill="#E1151D" Stroke="White" StrokeThickness="1"
                                 IsHitTestVisible="False" Focusable="False" />
                        <Ellipse Fill="White" Width="2.5" Height="2.5" HorizontalAlignment="Center"
                                 VerticalAlignment="Center" IsHitTestVisible="False" Focusable="False" />
                        <Grid.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="Calibration Point 1" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="X: " />
                                        <TextBlock Text="{Binding Settings.Point1.X, StringFormat=F1}" />
                                        <TextBlock Text=", Y: " Margin="5,0,0,0" />
                                        <TextBlock Text="{Binding Settings.Point1.Y, StringFormat=F1}" />
                                    </StackPanel>
                                </StackPanel>
                            </ToolTip>
                        </Grid.ToolTip>
                    </Grid>
                    <Grid Opacity="{Binding EffectiveOpacity}" x:Name="CalibMarker2" Background="Transparent"
                          Width="30"
                          Height="30" Margin="-15,-15" Focusable="False">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Settings.IsCalibrated}" Value="True" />
                                            <Condition Binding="{Binding Settings.ShowCalibrationMarkers}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Ellipse Width="10" Height="10" Fill="Green" Stroke="White" StrokeThickness="1"
                                 IsHitTestVisible="False" Focusable="False" />
                        <Ellipse Fill="White" Width="2.5" Height="2.5" HorizontalAlignment="Center"
                                 VerticalAlignment="Center" IsHitTestVisible="False" Focusable="False" />
                        <Grid.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="Calibration Point 2" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="X: " />
                                        <TextBlock Text="{Binding Settings.Point2.X, StringFormat=F1}" />
                                        <TextBlock Text=", Y: " Margin="5,0,0,0" />
                                        <TextBlock Text="{Binding Settings.Point2.Y, StringFormat=F1}" />
                                    </StackPanel>
                                </StackPanel>
                            </ToolTip>
                        </Grid.ToolTip>
                    </Grid>

                    <!-- Location Indicators -->
                    <ItemsControl Opacity="{Binding EffectiveOpacity}" ItemsSource="{Binding Locations}"
                                  Visibility="{Binding ShowLocations, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Focusable="False" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding PixelX}" />
                                <Setter Property="Canvas.Top" Value="{Binding PixelY}" />
                                <Setter Property="Focusable" Value="False" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent" Visibility="{Binding Visibility}"
                                      ToolTipService.InitialShowDelay="200"
                                      ToolTipService.ShowDuration="30000"
                                      ToolTipService.BetweenShowDelay="0" Focusable="False">
                                    <Ellipse Width="30" Height="30" Fill="Transparent" Margin="-15,-20,0,0"
                                             IsHitTestVisible="True" Focusable="False" />
                                    <Path
                                        Data="M 0,0 L -3.5,-5.5 A 4,4 0 1 1 3.5,-5.5 Z M 0,-7.5 A 1.5,1.5 0 1 0 0.0001,-7.5"
                                        Fill="#E1151D" Stroke="White" StrokeThickness="1"
                                        IsHitTestVisible="False" Focusable="False">
                                        <Path.RenderTransform>
                                            <ScaleTransform ScaleX="1.25" ScaleY="1.25" />
                                        </Path.RenderTransform>
                                    </Path>
                                    <Ellipse x:Name="TooltipAnchor" Width="1" Height="1" Fill="Transparent"
                                             Margin="0,-9.375,0,0" IsHitTestVisible="False" Focusable="False" />
                                    <Grid.ToolTip>
                                        <ToolTip Content="{Binding Tooltip}" Placement="Top"
                                                 PlacementTarget="{Binding ElementName=TooltipAnchor}"
                                                 Focusable="False" />
                                    </Grid.ToolTip>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </ScrollViewer>

            <Canvas IsHitTestVisible="False">
                <Canvas.Style>
                    <Style TargetType="Canvas">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Settings.IsCalibrated}" Value="True" />
                                    <Condition Binding="{Binding MapImage, Converter={StaticResource NullToVisibilityConverter}}" Value="Collapsed" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Canvas.Style>
                
                <Border Background="#80000000"
                        CornerRadius="3"
                        Padding="5,2"
                        Margin="0,5,0,0"

                        Canvas.Left="{Binding StickyLeftPosition}"
                        Canvas.Top="{Binding StickyTopPosition}"
                        IsHitTestVisible="False">
                    
                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,0"
                        Focusable="False">
                        <TextBlock Text="{Binding HoverCoordinatesLabel}"
                                   Foreground="#AAAAAA" VerticalAlignment="Center"
                                   FontSize="11"
                                   Margin="0,0,0,0" Focusable="False">
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Canvas>

            <Popup x:Name="WakeHintPopup"
                   Opened="WakeHintPopup_Opened"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   VerticalOffset="5"
                   Width="450"
                   IsHitTestVisible="False">
                <Popup.Style>
                    <Style TargetType="Popup">
                        <Setter Property="IsOpen" Value="False" />

                        <Style.Triggers>
                            <!-- <MultiDataTrigger> -->
                            <!--     <MultiDataTrigger.Conditions> -->
                            <!--         <Condition Binding="{Binding Settings.HideMapClickHint}" Value="True" /> -->
                            <!--     </MultiDataTrigger.Conditions> -->
                            <!--     <Setter Property="Visibility" Value="Collapsed" /> -->
                            <!-- </MultiDataTrigger> -->

                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource ComparisonConverter}">
                                        <Binding ElementName="MapCanvas" Path="ActualHeight" />
                                        <Binding Path="Settings.ZoomLevel" />
                                        <Binding ElementName="MapScrollViewer" Path="ActualHeight" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="PlacementTarget" Value="{Binding ElementName=MapCanvas}" />
                                <Setter Property="VerticalOffset"
                                        Value="{Binding PlacementTarget.ActualHeight, RelativeSource={RelativeSource Self}, 
                                    Converter={StaticResource HalfValueConverter}, ConverterParameter=15}" />
                            </DataTrigger>
                            <DataTrigger Value="False">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource ComparisonConverter}">
                                        <Binding ElementName="MapCanvas" Path="ActualHeight" />
                                        <Binding Path="Settings.ZoomLevel" />
                                        <Binding ElementName="MapScrollViewer" Path="ActualHeight" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="PlacementTarget" Value="{Binding ElementName=MapScrollViewer}" />
                                <Setter Property="VerticalOffset"
                                        Value="{Binding PlacementTarget.ActualHeight, RelativeSource={RelativeSource Self}, 
                                    Converter={StaticResource HalfValueConverter}, ConverterParameter=-40}" />
                            </DataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding UIVisibility}" Value="Collapsed" />
                                    <Condition Binding="{Binding AppSettings.HideMapClickHint}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="IsOpen" Value="True" />
                            </MultiDataTrigger>

                            <DataTrigger
                                Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                Value="Minimized">
                                <Setter Property="IsOpen" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Popup.Style>

                <Grid x:Name="PopupRoot" HorizontalAlignment="Center">
                    <Border Background="#CC2F3B2F"
                            Padding="10,5"
                            CornerRadius="5"
                            BorderBrush="Gold"
                            IsHitTestVisible="True"
                            HorizontalAlignment="Left"
                            BorderThickness="1"
                            Margin="10,0,0,0">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DOUBLE-CLICK MAP TO RESTORE CONTROLS"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                            <Button Click="HideHint_Click"
                                    Margin="10,0,0,3"
                                    Padding="2,0"
                                    Background="Transparent"
                                    Foreground="Gold"
                                    BorderThickness="0"
                                    Content="×"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="Hide this hint permanently" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Popup>

            <Rectangle Width="18" Height="18"
                       Fill="{Binding EffectiveTransparentBrush}"
                       Visibility="{Binding UIVisibility}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False" />
            <!-- Watermark Layer -->
            <TextBlock Text="NOT CALIBRATED"
                       FontSize="40"
                       Foreground="Gold"
                       Opacity="0.3"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding Settings.IsCalibrated}" Value="False">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Settings.IsCalibrated}" Value="True" />
                                    <Condition Binding="{Binding MapImage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Collapsed" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Watermark Layer -->
            <TextBlock Text="LOAD MAP"
                       FontSize="40"
                       Foreground="LightGray"
                       Opacity="1"
                       Visibility="{Binding MapImage, Converter={StaticResource NullToVisibilityConverter}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False">

            </TextBlock>
        </Grid>
        <!-- Opacity Slider -->
        <Border Grid.Row="3"
                Style="{StaticResource MainBorderStyle}"
                Padding="10,5,10,5"
                Visibility="{Binding UIVisibility}" Focusable="False">

            <StackPanel Orientation="Horizontal" Focusable="False">
                <TextBlock Text="Opacity" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11"
                           Focusable="False" />
                <Slider Width="100" Minimum="0.1" Maximum="1.0" Value="{Binding Opacity}" VerticalAlignment="Center"
                        TickFrequency="0.05" IsSnapToTickEnabled="True" Focusable="False">
                    <Slider.Style>
                        <Style TargetType="Slider">
                            <Setter Property="IsEnabled" Value="True" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition
                                            Binding="{Binding MapImage, Converter={StaticResource NullToVisibilityConverter}}"
                                            Value="Visible" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="IsEnabled" Value="False" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Slider.Style>
                </Slider>

                <TextBlock x:Name="StatusTextBlock" Foreground="White" VerticalAlignment="Center" Margin="20,0,10,0"
                           Text="Status: Ready" Focusable="False" />
            </StackPanel>
        </Border>
    </Grid>
</controls:ChildWindow>