<controls:ChildWindow x:Class="MMONavigator.Views.DestinationDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MMONavigator.Helpers"
             xmlns:controls="clr-namespace:MMONavigator.Controls"
             Title="Remember Destination" Height="210" Width="300" 
             WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
             Background="#2D2D30" Foreground="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" x:Name="PromptLabel" Text="Enter name for location: (Ex. boss name, landmark)" Margin="0,0,0,5" Foreground="White"
                   Height="30"
                   />
        <TextBox x:Name="InputTextBox" Grid.Row="1" VerticalAlignment="Center" 
                 Background="#3E3E42" Foreground="White" BorderBrush="#555555"
                 Padding="2" 
                 Margin="0,0,0,5"
                 Height="30"
                 helpers:ClickThroughBehavior.IsEnabled="True"
                 />
        
        <TextBlock Grid.Row="2" x:Name="GroupLabel" Text="Enter group: (optional, Ex. zone or dungeon)" Margin="0,0,0,5" Foreground="White"
                    Height="30"/>
        <!-- <TextBox Grid.Row="3" x:Name="GroupTextBox"  VerticalAlignment="Center"  -->
        <!--           Background="#3E3E42" Foreground="White" BorderBrush="#555555" -->
        <!--           Padding="2"  -->
        <!--           Margin="0,0,0,5" -->
        <!--           Height="30" -->
        <!-- /> -->
        
        <ComboBox Grid.Row="3"
            x:Name="GroupTextBox"
            ItemsSource="{Binding Groups}"
            SelectedItem="{Binding SelectedGroup}"
            IsEditable="True"
            Height="30"
            FontSize="8pt"
            helpers:ClickThroughBehavior.IsEnabled="True"
            Style="{StaticResource MainEditableComboBoxStyle}"
            VerticalAlignment="Center"/>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="75" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"
                    Style="{StaticResource MainButtonStyle}"/>
            <Button Content="Cancel" Width="75" Click="CancelButton_Click" IsCancel="True"
                    Style="{StaticResource MainButtonStyle}"/>
        </StackPanel>
    </Grid>
</controls:ChildWindow>
