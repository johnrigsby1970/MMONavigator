<Window x:Class="MMONavigator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MMONavigator.Views"
        xmlns:controls="clr-namespace:MMONavigator.Controls"
        xmlns:models="clr-namespace:MMONavigator.Models"
        xmlns:mmoNavigator="clr-namespace:MMONavigator"
        mc:Ignorable="d"
        Title="MainWindow"
        Width="300" Height="Auto" SizeToContent="WidthAndHeight"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <!-- <Window.Background> -->
    <!--     <SolidColorBrush Color="Transparent" /> -->
    <!-- </Window.Background> -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="TextStroke" Color="black" />
        <SolidColorBrush x:Key="TextFill" Color="white" />
        <SolidColorBrush x:Key="TitleBar" Opacity="0.1" Color="White" />
        <local:MainWindow x:Key="MainWindow" />
        <x:Static Member="local:MainWindow.StandardRowHeight" x:Key="StandardRowHeight" />
        <x:Static Member="local:MainWindow.StandardGridRowHeight" x:Key="StandardGridRowHeight" />
    </Window.Resources>
        <Grid Name="myGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="115" />
            <ColumnDefinition Width="185" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"></RowDefinition>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Rectangle Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Fill="{StaticResource TitleBar}"
                   MouseEnter="TitleBar_MouseEnter" MouseLeave="TitleBar_MouseLeave">
        </Rectangle>
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Height="{StaticResource StandardRowHeight}"
              VerticalAlignment="Top" Background="Transparent"
              MouseEnter="TitleBar_MouseEnter" MouseLeave="TitleBar_MouseLeave">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="dragbutton" Width="24" Height="24" Margin="3" Background="CornflowerBlue"
                        PreviewMouseLeftButtonDown="Rectangle_MouseLeftButtonDown" ToolTip="Drag Window"
                        Content="&#xF271;" FontFamily="Segoe MDL2 Assets" FontSize="12pt"
                        Foreground="White" FontWeight="ExtraBold">
                </Button>
                <Button x:Name="mapbutton" Width="24" Height="24" Margin="3" Content="&#xE707;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12pt"
                        ToolTip="Open Map" FontWeight="ExtraBold"
                        Command="{Binding OpenMapCommand}"
                        Foreground="White" Background="CornflowerBlue">
                </Button>
                <Button x:Name="settingsbutton" Width="24" Height="24" Margin="3" Content="&#xE713;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12pt"
                        ToolTip="Toggle Settings" FontWeight="ExtraBold"
                        Click="HideShowSettings_Click" Foreground="White" Background="CornflowerBlue"
                        IsEnabled="{Binding MainContentVisibility}"
                        Visibility="Collapsed">
                </Button>
                <Button x:Name="timerbutton" Width="24" Height="24" Margin="3"
                        Content="&#xED5A;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12pt"
                        ToolTip="Toggle Timers" FontWeight="ExtraBold"
                        IsEnabled="{Binding MainContentVisibility}"
                        Click="HideShowTimers_Click" Foreground="White" Background="CornflowerBlue"
                        Visibility="Collapsed">
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="togglebutton" Width="24" Height="24"
                        Content="&#xE7B3;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12pt"
                        Margin="3" Click="ToggleVisibityButton_Click"
                        Foreground="White" ToolTip="Hide Directions" Background="CornflowerBlue"
                        Visibility="Collapsed">
                </Button>
                <!-- <Button x:Name="minbutton" Width="24" Height="24" -->
                <!--         FontSize="12pt" -->
                <!--         Margin="3" Click="MinimizeButton_Click" -->
                <!--         Foreground="White" ToolTip="Minimize" Background="CornflowerBlue" -->
                <!--         Visibility="Collapsed"> -->
                <!--     _ -->
                <!-- </Button> -->
                <Button x:Name="closebutton" Width="24" Height="24"
                        FontSize="12pt"
                        Margin="3" Click="CloseButton_Click" Foreground="White"
                        ToolTip="Close" Background="CornflowerBlue"
                        Visibility="Collapsed">
                    X
                </Button>
            </StackPanel>
        </Grid>

        <Grid Row="1" Grid.Column="0" Grid.ColumnSpan="2"
              Visibility="{Binding MainContentVisibility, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Name="destinationRow">
                    <RowDefinition.Style>
                        <Style TargetType="RowDefinition">
                            <Setter Property="Height" Value="30"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSettings}" Value="False">
                                    <Setter Property="Height" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RowDefinition.Style>
                </RowDefinition>
                <RowDefinition Name="targetRow">
                    <RowDefinition.Style>
                        <Style TargetType="RowDefinition">
                            <Setter Property="Height" Value="30"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSettings}" Value="False">
                                    <Setter Property="Height" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RowDefinition.Style>
                </RowDefinition>
                <RowDefinition Name="timerRow">
                    <RowDefinition.Style>
                        <Style TargetType="RowDefinition">
                            <Setter Property="Height" Value="30"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTimers}" Value="False">
                                    <Setter Property="Height" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RowDefinition.Style>
                </RowDefinition>
                <RowDefinition Height="50" Name="directionRow" />
                <RowDefinition Height="Auto" Name="compassRow" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" FlowDirection="LeftToRight"
                        Orientation="Horizontal"
                        Visibility="{Binding ShowSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                <controls:OutlinedTextBlock
                    Text="Destination:"
                    FontFamily="Verdana" FontSize="10pt"
                    FontWeight="ExtraBold"
                    TextWrapping="Wrap"
                    StrokeThickness=".5"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    TextAlignment="Left"
                    Width="100"
                    Margin="5,1,0,0"
                    Stroke="{StaticResource TextStroke}"
                    Fill="{StaticResource TextFill}" />

                <!-- <ComboBox -->
                <!--     ItemsSource="{Binding Locations}" -->
                <!--     SelectedItem="{Binding SelectedLocation}" -->
                <!--     Text="{Binding TargetCoordinates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" -->
                <!--     IsEditable="True" -->
                <!--     DisplayMemberPath="DisplayName" -->
                <!--     Height="22" -->
                <!--     FontSize="8pt" -->
                <!--     VerticalAlignment="Center" Width="140" -->
                <!--     ToolTip="{Binding DestinationTooltip}" /> -->

                <TextBox x:Name="TargetCoordinates" 
                         Text="{Binding TargetCoordinates ,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="22" 
                         FontSize="8pt"
                         Margin="0,0,0,0"
                         VerticalAlignment="Center" 
                         Width="99"
                         ToolTip="{Binding DestinationTooltip}"
                         GotFocus="TextBox_GotFocus"
                         LostFocus="TextBox_LostFocus"
                         PreviewMouseDown="TextBox_PreviewMouseDown"/>
                <!--https://stackoverflow.com/questions/722700/wpf-treeview-inside-a-combobox-->
                <Expander Header="TestCS" Width="25" Height="25"
                          Visibility="{Binding HasLocations, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Popup 
                        PlacementTarget="{Binding ElementName=TargetCoordinates}"
                        IsOpen="{Binding IsExpanded, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Expander}}}"
                        StaysOpen="False"
                        Margin="1,1,1,1"
                        Width="200"
                        >
                        <mmoNavigator:ExtendedTreeView 
                            ItemsSource="{Binding Locations}" 
                            SelectedItem_="{Binding SelectedLocation, Mode=TwoWay}" 
                            Margin="1,1,1,1"
                            Width="200" >
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="{x:Type TreeViewItem}">
                                    <!-- Bind the IsSelected property of the TreeViewItem to a property on your ViewModel item -->
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <!-- You can also bind IsExpanded this way -->
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <!-- The DataTemplate for the 'Node' class -->
                                <HierarchicalDataTemplate DataType="{x:Type models:LocationItem}" ItemsSource="{Binding Items}">
                                    <TextBlock Text="{Binding DisplayName}" 
                                               FontSize="8pt"
                                               Width="150"
                                               Margin="0,1,0,1"
                                               ToolTip="{Binding DestinationTooltip}"/>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </mmoNavigator:ExtendedTreeView>
                    </Popup>
                </Expander>
                
                <Button x:Name="addlocation" Width="20" Height="20" Margin="3,0,0,0" 
                        Content="&#xE710;" 
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Remember Destination" FontWeight="ExtraBold"
                        Visibility="{Binding IsItemInListAndHasValue, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding AddLocationCommand}" Foreground="White" Background="CornflowerBlue">
                </Button>
                
                <Button Width="20" Height="20" Margin="3,0,0,0" 
                        Content="&#xE70F;"
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Edit Destination" FontWeight="ExtraBold"
                        Visibility="{Binding IsItemInList, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding EditLocationCommand}" Foreground="White" Background="CornflowerBlue">
                </Button>

                <Button Width="20" Height="20" Margin="3,0,0,0"
                        Content="&#xE74D;"
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Forget Destination" FontWeight="ExtraBold"
                        Visibility="{Binding IsItemInList, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding RemoveLocationCommand}" Foreground="White" Background="OrangeRed">
                </Button>
                
                <Button Width="20" Height="20" Margin="3,0,0,0"
                        Content="&#xE8E5;"
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Select Locations File" FontWeight="ExtraBold"
                        Command="{Binding SelectLocationFileCommand}" Foreground="White" Background="CornflowerBlue">
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" FlowDirection="LeftToRight"
                        Orientation="Horizontal"
                        Visibility="{Binding ShowSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                <controls:OutlinedTextBlock
                    Text="Location:"
                    FontFamily="Verdana" FontSize="10pt"
                    FontWeight="ExtraBold"
                    TextWrapping="Wrap"
                    StrokeThickness=".5"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    TextAlignment="Left"
                    Width="100"
                    Margin="5,1,0,0"
                    Stroke="{StaticResource TextStroke}"
                    Fill="{StaticResource TextFill}" />

                <TextBox
                    Text="{Binding CurrentCoordinates ,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Height="20" Margin="0,1,4,0"
                    FontSize="8pt"
                    VerticalAlignment="Center" Width="120"
                    ToolTip="{Binding LocationTooltip}"
                    GotFocus="TextBox_GotFocus"
                    LostFocus="TextBox_LostFocus"
                    PreviewMouseDown="TextBox_PreviewMouseDown" />

                <Button Width="20" Height="20" Margin="3" 
                        Content="&#xF272;"
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Copy Location to Destination" FontWeight="ExtraBold"
                        Command="{Binding CopyLocationToDestinationCommand}" Foreground="White"
                        Background="CornflowerBlue">
                </Button>

                <Button Width="20" Height="20" Margin="0,3,3,3"
                        Content="&#xE77B;"
                        FontFamily="Segoe MDL2 Assets" 
                        ToolTip="Configure Location Watcher" FontWeight="ExtraBold"
                        Click="ConfigureWatcher_Click" Foreground="White" Background="CornflowerBlue">
                </Button>

            </StackPanel>
            
            <StackPanel Grid.Row="2" Grid.Column="0" FlowDirection="LeftToRight"
                        Orientation="Horizontal" HorizontalAlignment="Center"
                        Visibility="{Binding ShowTimers, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button Width="60" Height="24"  Margin="13,3,3,3"
                        Background="{Binding Timer5.Background}"
                        Foreground="{Binding Timer5.Foreground}"
                        Command="{Binding TimerCommand}" CommandParameter="{Binding Timer5}" FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED5A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                   Margin="0,0,5,0" />
                        <TextBlock Text="{Binding Timer5.DisplayText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Width="60" Height="24" Margin="3"
                        Background="{Binding Timer10.Background}"
                        Foreground="{Binding Timer10.Foreground}"
                        Command="{Binding TimerCommand}" CommandParameter="{Binding Timer10}" FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED5A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                   Margin="0,0,5,0" />
                        <TextBlock Text="{Binding Timer10.DisplayText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Width="60" Height="24" Margin="3"
                        Background="{Binding Timer15.Background}"
                        Foreground="{Binding Timer15.Foreground}"
                        Command="{Binding TimerCommand}" CommandParameter="{Binding Timer15}" FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED5A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                   Margin="0,0,5,0" />
                        <TextBlock Text="{Binding Timer15.DisplayText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Width="60" Height="24" Margin="3"
                        Background="{Binding Timer20.Background}"
                        Foreground="{Binding Timer20.Foreground}"
                        Command="{Binding TimerCommand}" CommandParameter="{Binding Timer20}" FontWeight="Bold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xED5A;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"
                                   Margin="0,0,5,0" />
                        <TextBlock Text="{Binding Timer20.DisplayText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" FlowDirection="LeftToRight"
                        Orientation="Horizontal" Background="Transparent"
                        MouseEnter="DirectionsArea_MouseEnter" MouseLeave="DirectionsArea_MouseLeave">
                <TextBox x:Name="leftbutton" Width="20" Height="20" Margin="3"
                         VerticalAlignment="Center" VerticalContentAlignment="Center" TextAlignment="Center"
                         Text="&#xF0D5;" FontFamily="Segoe MDL2 Assets"
                         ToolTip="Turn left" FontWeight="ExtraBold" Foreground="White" Background="Chartreuse"
                         Visibility="{Binding LeftButtonVisibility}"
                         IsReadOnly="True">
                </TextBox>

                <controls:OutlinedTextBlock x:Name="labelDirection"
                                            Text="{Binding GoDirection , UpdateSourceTrigger=PropertyChanged}"
                                            FontFamily="Verdana" FontSize="12pt"
                                            FontWeight="ExtraBold"
                                            TextWrapping="Wrap"
                                            StrokeThickness="1"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            Width="245"
                                            Stroke="{StaticResource TextStroke}"
                                            Fill="{Binding LabelDirectionFill}"
                                            />
                <TextBox x:Name="rightbutton"
                         VerticalAlignment="Center" VerticalContentAlignment="Center" TextAlignment="Center"
                         Width="20" Height="20" Margin="3" Text="&#xF0D6;" FontFamily="Segoe MDL2 Assets"
                         ToolTip="Turn right" FontWeight="ExtraBold" Foreground="White" Background="Chartreuse"
                         Visibility="{Binding RightButtonVisibility}"
                         IsReadOnly="True">
                </TextBox>
            </StackPanel>

            <Grid Grid.Row="4" Background="Transparent"
                  MouseEnter="CompassArea_MouseEnter" MouseLeave="CompassArea_MouseLeave">
                <Grid IsHitTestVisible="False">
                    <!-- Compass Circle -->
                    <Ellipse Width="80" Height="80" Stroke="{Binding CompassBrush}" StrokeThickness="3"
                             HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />

                    <!-- Distance in center -->
                    <TextBlock Text="{Binding DistanceInt}" Foreground="{Binding CompassBrush}" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14pt"
                               IsHitTestVisible="False" />
                </Grid>

                <!-- Coffee cup icon -->
                <!-- <Button Command="{Binding BuyMeACoffeeCommand}" -->
                <!--         Visibility="{Binding ShowCoffeeIcon}" -->
                <!--         HorizontalAlignment="Center" VerticalAlignment="Center" -->
                <!--         Margin="100,100,0,0" -->
                <!--         BorderThickness="0" -->
                <!--         Background="Transparent" -->
                <!--         Padding="0" Cursor="Hand" -->
                <!--         ToolTip="Buy me a coffee!" -->
                <!--         > -->
                <!--     <TextBlock Text="&#xE8E1;" FontFamily="Segoe MDL2 Assets"  -->
                <!--                FontSize="10pt" Foreground="{Binding CompassBrush}"  IsHitTestVisible="true"/> -->
                <!-- </Button> -->

                <!-- Indicators -->
                <Grid Width="120" Height="120" HorizontalAlignment="Center" Background="{x:Null}"
                      VerticalAlignment="Center" IsHitTestVisible="False">
                    <Grid.RenderTransform>
                        <RotateTransform Angle="{Binding NorthRotation}" CenterX="60" CenterY="60" />
                    </Grid.RenderTransform>

                    <!-- North -->
                    <Line X1="60" Y1="20" X2="60" Y2="30" Stroke="{Binding CompassBrush}" StrokeThickness="3"
                          IsHitTestVisible="False" />
                    <TextBlock Text="N" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="14pt"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-5,0,0"
                               IsHitTestVisible="False" />

                    <!-- NorthEast -->
                    <Grid Width="120" Height="120" IsHitTestVisible="False">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="45" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="NE" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- East -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="90" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="E" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- SouthEast -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="135" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="SE" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- South -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="180" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="S" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- SouthWest -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="225" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="SW" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- West -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="270" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="W" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>

                    <!-- NorthWest -->
                    <Grid Width="120" Height="120">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="315" CenterX="60" CenterY="60" />
                        </Grid.RenderTransform>
                        <Line X1="60" Y1="20" X2="60" Y2="25" Stroke="{Binding CompassBrush}" StrokeThickness="2" />
                        <TextBlock Text="NW" Foreground="{Binding CompassBrush}" FontWeight="Bold" FontSize="10pt"
                                   HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,0,0,0" />
                    </Grid>
                </Grid>

                <!-- Destination Dot -->
                <Grid Width="80" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center"
                      IsHitTestVisible="False"
                      Visibility="{Binding DestinationVisibility}">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform Y="{Binding DestinationOffset}" />
                            <RotateTransform Angle="{Binding DestinationRotation}" CenterX="40" CenterY="40" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Ellipse Width="10" Height="10" Fill="LimeGreen" HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>