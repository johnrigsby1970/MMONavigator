<Window x:Class="MMONavigator.Views.About"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:MMONavigator.Views"
        mc:Ignorable="d"
        Background="Black"
        Title="About" Height="450" Width="800">
    <Grid Margin="10">
        <TabControl Background="LightGray">
            <!-- Tab 1: Your App's GPL v3.0 License -->
            <TabItem Header="Application License">
                <TextBox Name="MainLicenseTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         FontFamily="Consolas" Margin="5"/>
            </TabItem>
            
            <!-- Tab 2: Dependency & NuGet Licenses -->
            <TabItem Header="Third-Party Notices">
                <TextBox Name="ThirdPartyTextBox" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         FontFamily="Consolas" Margin="5"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
