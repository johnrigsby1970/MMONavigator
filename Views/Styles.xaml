<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="BrandingResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <Style x:Key="MainButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonForegroundBrush}" />
    </Style>
    
    <Style x:Key="CalibrationButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonForegroundBrush}" />
    
        <Style.Triggers>
            <DataTrigger Binding="{Binding Settings.IsCalibrated}" Value="False">
                <Setter Property="BorderBrush" Value="{StaticResource HighlightBorderBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryButtonForegroundBrush}" />
    </Style>
    
    <Style x:Key="DeleteButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DeleteButtonBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource DeleteButtonForegroundBrush}" />
    </Style>
    
    <Style x:Key="MainTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource FormControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FormControlForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FormControlBorderBrush}" />
    </Style>


    <Style x:Key="MainBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderBackgroundBrush}" />
    </Style>
    
    <Style x:Key="MainScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="{StaticResource BorderBackgroundBrush}" />
    </Style>
    
    <Style x:Key="MainGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource GridBackgroundBrush}" />
    </Style>
    
    <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource FormControlForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource FormControlBackgroundBrush}" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource FormControlForegroundBrush}" />
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="ItemBorder" 
                            Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource FormControlBorderBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource FormControlForegroundBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

<Style x:Key="MainEditableComboBoxStyle" TargetType="ComboBox">
    <Style.Resources>
        <Style x:Key="ComboBoxTextBoxStyle" TargetType="TextBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" /> 
            <Setter Property="Margin" Value="0" />
            <Setter Property="SelectionBrush" Value="Transparent" /> 
            <Setter Property="Foreground" Value="{StaticResource FormControlForegroundBrush}" />
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{StaticResource FormControlBackgroundBrush}" 
                                BorderBrush="{StaticResource FormControlBorderBrush}" 
                                BorderThickness="1,0,0,0">
                            <Path x:Name="Arrow" 
                                  Fill="{StaticResource FormControlForegroundBrush}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Data="M 0 0 L 4 4 L 8 0 Z" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Style.Resources>

    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ComboBox">
                <Border x:Name="MainBorder" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PART_EditableTextBox"
                                 Grid.Column="0"
                                 Style="{StaticResource ComboBoxTextBoxStyle}"
                                 Background="{StaticResource FormControlBackgroundBrush}"
                                 Foreground="{StaticResource FormControlForegroundBrush}"
                                 VerticalAlignment="Stretch"
                                 HorizontalAlignment="Stretch"
                                 BorderThickness="0"
                                 Padding="4,3,4,0" 
                                 Margin="0"
                                 SnapsToDevicePixels="True" />

                        <ToggleButton x:Name="ToggleButton" 
                                      Grid.Column="1"
                                      Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />
            
                        <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="{StaticResource FormControlBackgroundBrush}" 
                                        BorderThickness="1" 
                                        BorderBrush="{StaticResource FormControlBorderBrush}"/>
                                <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" 
                                                TextElement.Foreground="{StaticResource FormControlForegroundBrush}" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </Border>
            </ControlTemplate>
            

        </Setter.Value>
    </Setter>
</Style>
    
<Style x:Key="MainComboBoxStyle" TargetType="ComboBox">
    
    <Style.Resources>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{StaticResource FormControlBackgroundBrush}" 
                                BorderBrush="{StaticResource FormControlBorderBrush}" 
                                BorderThickness="1,0,0,0">
                            <Path x:Name="Arrow" 
                                  Fill="{StaticResource FormControlForegroundBrush}" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Data="M 0 0 L 4 4 L 8 0 Z" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Style.Resources>
    
    <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}" />
    <Setter Property="Background" Value="{StaticResource FormControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource FormControlForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource FormControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="4,2" />
    
    
    
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ComboBox">
                <Border x:Name="MainBorder" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"
                                          TextElement.Foreground="{StaticResource FormControlForegroundBrush}" />

                        <ToggleButton x:Name="ToggleButton" 
                                      Grid.Column="1"
                                      Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />

                        <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="{StaticResource FormControlBackgroundBrush}" 
                                        BorderThickness="1" 
                                        BorderBrush="{StaticResource FormControlBorderBrush}"/>
                                <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" TextElement.Foreground="{StaticResource FormControlForegroundBrush}" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
    
</ResourceDictionary>